# انسخ هذا الملف إلى .env وأدخل القيم الحقيقية
# cp .env.example .env

FLASK_ENV=production
SECRET_KEY=change-this-to-a-random-string-at-least-32-chars
DATABASE_URL=sqlite:///solar_v8.db
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_strong_password_here

# Deye Cloud OpenAPI
DEYE_REGION=EMEA
DEYE_BASE_URL=https://eu1-developer.deyecloud.com/v1.0
DEYE_APP_ID=
DEYE_APP_SECRET=
DEYE_EMAIL=
DEYE_PASSWORD=
DEYE_PASSWORD_HASH=
DEYE_PLANT_ID=
DEYE_DEVICE_SN=           # Inverter SN (e.g. 2504265119)
DEYE_LOGGER_SN=           # Logger SN (e.g. 3434586752) — مهم لبيانات PV والانفيرتر التفصيلية
DEYE_PLANT_NAME=

LOCAL_TIMEZONE=Asia/Hebron
BATTERY_CAPACITY_KWH=5
BATTERY_RESERVE_PERCENT=20
DEYE_BATTERY_SN_MAIN=
DEYE_BATTERY_SN_MODULE=

AUTO_SYNC_ENABLED=true
AUTO_SYNC_MINUTES=5

# حدود الأداء
MAX_READINGS_QUERY=2000
SYNCLOG_RETENTION_DAYS=30
NOTIFICATIONLOG_RETENTION_DAYS=90

# بيانات البطارية الثابتة (اختياري)
BATTERY_KNOWN_VOLTAGE=
BATTERY_KNOWN_CURRENT=
BATTERY_KNOWN_HEALTH=
BATTERY_KNOWN_CAPACITY_AH=
BATTERY_KNOWN_CYCLES=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
BATTERY_KNOWN_TEMPERATURE=
