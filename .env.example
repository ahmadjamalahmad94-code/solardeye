# Copy this file to .env and add real values. Never commit .env.
# cp .env.example .env

APP_ENV=production
FLASK_ENV=production
SECRET_KEY=replace-with-a-random-string-at-least-32-characters
DATABASE_URL=sqlite:///solar_v9.db
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-password
SESSION_COOKIE_SECURE=true
CSRF_ENABLED=true
SESSION_COOKIE_SAMESITE=Lax
DEBUG_TOOLS_ENABLED=false
TELEGRAM_WEBHOOK_SECRET=replace-with-random-secret-if-using-telegram-webhook

# Deye Cloud OpenAPI
DEYE_REGION=EMEA
DEYE_BASE_URL=https://eu1-developer.deyecloud.com/v1.0
DEYE_APP_ID=
DEYE_APP_SECRET=
DEYE_EMAIL=
DEYE_PASSWORD=
DEYE_PASSWORD_HASH=
DEYE_PLANT_ID=
DEYE_DEVICE_SN=
DEYE_LOGGER_SN=
DEYE_PLANT_NAME=

LOCAL_TIMEZONE=Asia/Hebron
BATTERY_CAPACITY_KWH=5
BATTERY_RESERVE_PERCENT=20
DEYE_BATTERY_SN_MAIN=
DEYE_BATTERY_SN_MODULE=

AUTO_SYNC_ENABLED=true
AUTO_SYNC_MINUTES=5
MAX_READINGS_QUERY=2000
SYNCLOG_RETENTION_DAYS=30
NOTIFICATIONLOG_RETENTION_DAYS=90

# Optional battery fallback values
BATTERY_KNOWN_VOLTAGE=
BATTERY_KNOWN_CURRENT=
BATTERY_KNOWN_HEALTH=
BATTERY_KNOWN_CAPACITY_AH=
BATTERY_KNOWN_CYCLES=
BATTERY_KNOWN_TEMPERATURE=

# OAuth / Social login
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_REDIRECT_URI=

# Backup automation
BACKUP_ENABLED=true
# BACKUP_FREQUENCY can be daily, weekly, or monthly
BACKUP_FREQUENCY=daily
BACKUP_KEEP_LOCAL=12
GOOGLE_DRIVE_BACKUP_ENABLED=false
GOOGLE_DRIVE_BACKUP_FOLDER_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SERVICE_ACCOUNT_FILE=
